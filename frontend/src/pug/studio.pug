doctype html
html(lang="en")
  head
    title Arbesk Studio
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="icon", type="image/png", href="/logo.png")
    link(rel="apple-touch-icon", href="/apple-touch-icon.png")
    link(rel="stylesheet", href="/css/styles.css")
    script(src="https://cdn.babylonjs.com/babylon.js")
    script(src="https://cdn.babylonjs.com/loaders/babylonjs.loaders.min.js")
    script(src="https://cdn.babylonjs.com/materialsLibrary/babylonjs.materials.min.js")
    script(src="https://cdn.jsdelivr.net/npm/web3@1.10.0/dist/web3.min.js")
    script(src="https://cdn.jsdelivr.net/npm/web3modal@1.9.12/dist/index.js")
  body
    #app
      //- ═══════════════════════════════════════════════════════════
      //- Header Bar (GNOME-style)
      //- ═══════════════════════════════════════════════════════════
      header.headerbar
        .headerbar-brand
          img(src="/logo.png", alt="Arbesk")

        button#backBtn.headerbar-back.hidden(aria-label="Go back to parent world", title="Go back (Alt+Left)")
          svg(width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
            path(d="M15 18l-6-6 6-6")

        button#newAssetTopBtn.btn.btn-secondary.btn-sm.headerbar-new(aria-label="New asset", title="New asset (Ctrl+N)")
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
            line(x1="12" y1="5" x2="12" y2="19")
            line(x1="5" y1="12" x2="19" y2="12")
          span New

        .headerbar-title
          nav#pathBar.pathbar.hidden(aria-label="World path")
          span#assetStatusName.headerbar-title-text(contenteditable="true") No asset open
          span#assetStatusMeta.headerbar-title-meta Create or open an asset

        #assetHistory.history(hidden)
          .history-track

        .headerbar-actions
          button#saveAssetBtn.btn.btn-secondary.btn-sm(hidden)
            svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              path(d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z")
              path(d="M17 21v-8H7v8")
              path(d="M7 3v5h8")
            span#saveAssetBtnText Save Draft
          button#publishAssetBtn.btn.btn-primary.btn-sm.headerbar-publish(hidden)
            svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              path(d="M12 3v12")
              path(d="M7 8l5-5 5 5")
              path(d="M5 15v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4")
            span#publishAssetBtnText Publish Asset
          button#connectWalletBtn.headerbar-wallet.disconnected(aria-label="Connect wallet" onclick="connectWallet()")
            svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              path(d="M21 12V7H5a2 2 0 0 1 0-4h14v4")
              path(d="M3 5v14a2 2 0 0 0 2 2h16v-5")
              path(d="M18 12a2 2 0 0 0 0 4h4v-4Z")
            span Connect Wallet
          button#disconnectWalletBtn.headerbar-wallet.hidden(aria-label="Disconnect wallet" onclick="disconnectWallet()")
            svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              path(d="M21 12V7H5a2 2 0 0 1 0-4h14v4")
              path(d="M3 5v14a2 2 0 0 0 2 2h16v-5")
              path(d="M18 12a2 2 0 0 0 0 4h4v-4Z")
            span Disconnect

      //- ═══════════════════════════════════════════════════════════
      //- Studio Layout
      //- ═══════════════════════════════════════════════════════════
      .studio-layout
        //- Unified Sidebar with View Switcher
        aside.sidebar
          .sidebar-switcher
            button.sidebar-switcher-btn.active(data-view="create" aria-label="Create" title="Create (Ctrl+1)")
              svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M12 20h9")
                path(d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z")
            button.sidebar-switcher-btn(data-view="outline" aria-label="Outline" title="Outline (Ctrl+2)")
              svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                circle(cx="12" cy="12" r="10")
                line(x1="12" y1="2" x2="12" y2="7")
                line(x1="12" y1="17" x2="12" y2="22")
                line(x1="2" y1="12" x2="7" y2="12")
                line(x1="17" y1="12" x2="22" y2="12")
            button.sidebar-switcher-btn(data-view="library" aria-label="Library" title="Library (Ctrl+3)")
              svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20")
                path(d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z")
            button.sidebar-switcher-btn(data-view="ledger" aria-label="Ledger" title="Ledger (Ctrl+4)")
              svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z")
                path(d="M14 2v6h6")
                path(d="M8 13h2")
                path(d="M8 17h2")
                path(d="M14 13h2")
                path(d="M14 17h2")
            .sidebar-switcher-bottom
              button#sidebarToggle.sidebar-switcher-toggle(aria-label="Collapse sidebar" title="Toggle sidebar (Ctrl+B)")
                svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                  polyline(points="15 18 9 12 15 6")
          .sidebar-content
            //- View: Create
            .sidebar-view(data-view="create")
              .sidebar-view-header
                h2 Create
              .sidebar-view-body
                #assetDefinition.asset-definition-section
                  .asset-def-header
                    button#toggleAssetDef.asset-def-toggle(aria-label="Toggle settings")
                      svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                        polyline(points="9 18 15 12 9 6")
                      span Settings
                  .asset-def-body(hidden)
                    .form-group
                      label.form-label Asset Name
                      #assetNameDisplay.form-input(style="background:transparent;border:none;padding:var(--size-2) 0") Untitled Asset
                    .form-group
                      label.form-label(for="providerSelect") Generation Provider
                      select#providerSelect.form-select
                        option(value="mock") Mock (Local)
                        option(value="meshy") Meshy
                        option(value="tripo3d") Tripo3D
                        option(value="hunyuan3d") Hunyuan3D
                    .form-group
                      label.form-label(for="tierSelect") Quality Tier
                      select#tierSelect.form-select
                        option(value="0" selected) Basic — 0.75 USDC
                        option(value="1") Standard — 1.25 USDC
                        option(value="2") Premium — 1.75 USDC
                        option(value="3") Pro — 2.50 USDC
                      .form-help Higher tiers produce better quality meshes.
                    #teamPanel.team-section(hidden)
                      .team-header
                        h5 Asset Editors
                        span#teamOwnerBadge.owner-badge(hidden) Owner
                      #teamList.team-list
                      .team-add
                        input#teamAddInput.form-control(type="text", placeholder="0x… wallet address")
                        button#teamAddBtn.btn.btn-sm Add Editor
                #chatHistory.chat-history
                  .chat-welcome
                    .welcome-icon ✦
                    p.welcome-text Create an asset
                    p.welcome-sub Describe the 3D asset you want to generate.
                #timeline.timeline-section(hidden)
                  label.timeline-label Asset Variants
                  .timeline-slider-wrap
                    input#versionSlider.timeline-slider(type="range", min="0", max="0", step="1")
                    span#versionLabel.version-badge v1

            //- View: Outline
            .sidebar-view(data-view="outline" hidden)
              .sidebar-view-header
                h2 Outline
                .outliner-toolbar
                  button#outlinerAddBtn.btn.btn-icon.btn-sm(aria-label="Add child world" title="Add child world")
                    svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                      line(x1="12" y1="5" x2="12" y2="19")
                      line(x1="5" y1="12" x2="19" y2="12")
                  button#outlinerRemoveBtn.btn.btn-icon.btn-sm(aria-label="Remove selected" title="Remove selected")
                    svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                      line(x1="5" y1="12" x2="19" y2="12")
              .sidebar-view-body
                .outliner
                  .outliner-tree
                  .outliner-footer No items

            //- View: Library
            .sidebar-view(data-view="library" hidden)
              .sidebar-view-header
                h2 Library
              .sidebar-view-body
                #assetLibraryBody.asset-library-body
                  p.asset-library-empty Connect wallet to browse your asset tokens.

            //- View: Ledger
            .sidebar-view(data-view="ledger" hidden)
              .sidebar-view-header
                h2 Ledger
              .sidebar-view-body
                #ledgerBody.ledger-panel-body
                  .ledger-panel-controls
                    select#ledgerFilter.ledger-filter
                      option(value="") All Operations
                      option(value="GENERATION") Generation
                      option(value="PARAMETRIC") Parametric
                      option(value="SAVE") Save
                      option(value="PUBLISH") Publish
                      option(value="THUMBNAIL") Thumbnail
                      option(value="MINT") Mint
                      option(value="TOKEN_URI_UPDATE") URI Update
                      option(value="TEAM_EDIT") Team Edit
                    button#ledgerAnchorBtn.ledger-anchor-btn(
                      title="Anchor current manifest CID on-chain for immutability proof"
                    ) Anchor Manifest
                  #ledgerStats.ledger-stats
                  ul#ledgerList.ledger-list

        //- Sidebar reveal button
        button#sidebarReveal.sidebar-reveal(aria-label="Show sidebar" title="Show sidebar (Ctrl+B)")
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            polyline(points="9 18 15 12 9 6")

        //- Main content area
        main#mainStage.main-stage
          #viewport.viewport
            canvas#renderCanvas
            canvas#viewportGizmo(aria-label="Viewport orientation gizmo" title="X Y Z orientation")

            #welcomeOverlay.viewport-empty
              .viewport-empty-content
                .viewport-empty-icon ✦
                h2 Welcome to Arbesk
                p Create, compose, and publish tokenized 3D assets.
                .viewport-empty-actions
                  button#newAssetBtn.btn.btn-primary Start New Asset
                  p(style="font-size:var(--font-size-0);color:var(--choco-4);margin-top:var(--size-2)") Generate an asset, open one from your library, or drag an asset into the scene.

            #assetDropOverlay.viewport-drop-indicator
              div(style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--accent-bg);font-weight:600")
                .asset-drop-icon ⊕
                p Drop to add linked asset to scene

          //- Message bar
          .messagebar
            textarea#promptInput.messagebar-input(placeholder="Describe the 3D asset you envision…" rows="1")
            button#generateBtn.messagebar-submit(aria-label="Generate asset")
              svg.messagebar-submit-icon(width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                polygon(points="12 2 22 12 12 22 12 16 2 16 2 8 12 8")
              .messagebar-spinner
            p#generateHint.messagebar-hint(hidden) Connect wallet to generate

        //- Inspector — right sidebar
        aside#inspector.inspector.collapsed
          .inspector-header
            h5 Selection Inspector
            button#inspectorCloseBtn.btn.btn-icon.btn-sm(aria-label="Close inspector")
              svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                line(x1="18" y1="6" x2="6" y2="18")
                line(x1="6" y1="6" x2="18" y2="18")
          .inspector-body
            #tokenChildInfo.inspector-token-child(hidden)
              .inspector-section
                .inspector-section-title Token Info
                .inspector-meta
                  .inspector-meta-row
                    span.label Linked Token
                    span#tokenChildId.value —
                  .inspector-meta-row
                    span.label Contract
                    span#tokenChildContract.value —
                  .inspector-meta-row
                    span.label Chain ID
                    span#tokenChildChain.value —
                  .inspector-meta-row
                    span.label Resolution
                    span#tokenChildResolution.value latest
                  .inspector-meta-row
                    span.label Manifest CID
                    span#tokenChildCid.value(style="font-family:var(--font-mono);font-size:var(--font-size-0);word-break:break-all") —
              .inspector-actions
                button#inspectorDiveBtn.btn.btn-primary(style="width:100%") Open This World &rarr;
            #parametricEditor
              .inspector-section
                .inspector-section-title Appearance
                .form-group
                  label.form-label(for="nodeColor") Color
                  input#nodeColor.form-color(type="color", value="#C19A6B")
              .inspector-section
                .inspector-section-title Transform
                .form-group
                  label.form-label(for="nodeScaleX") Scale X
                  input#nodeScaleX.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
                .form-group
                  label.form-label(for="nodeScaleY") Scale Y
                  input#nodeScaleY.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
                .form-group
                  label.form-label(for="nodeScaleZ") Scale Z
                  input#nodeScaleZ.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
              .inspector-actions
                button#saveParametric.btn.btn-primary Save Variant
                button#cancelParametric.btn.btn-secondary Cancel

      //- ═══════════════════════════════════════════════════════════
      //- Bottom Bar
      //- ═══════════════════════════════════════════════════════════
      footer#bottomBar.bottombar
        .bottombar-status
          span#bottomBarStatus.bottombar-status-item Draft
          span.bottombar-status-item Provider: Mock

    script(type="module", src="/js/engine/scene-graph.js")
    script(type="module", src="/js/engine/time-travel.js")
    script(type="module", src="/js/engine/parametric-preview.js")
    script(type="module", src="/js/blockchain/token-resolver.js")
    script(type="module", src="/js/blockchain/wallet.js")
    script(type="module", src="/js/services/api.js")
    script(type="module", src="/js/services/team.js")
    script(type="module", src="/js/ui/asset-editors.js")
    script(type="module", src="/js/ui/asset-save.js")
    script(type="module", src="/js/ui/asset-history.js")
    script(type="module", src="/js/ui/create-panel.js")
    script(type="module", src="/js/ui/asset-drop-zone.js")
    script(type="module", src="/js/ui/sidebar.js")
    script(type="module", src="/js/ui/outliner.js")
    script(type="module", src="/js/ui/nesting.js")
    script(type="module").
      import { initAssetLibrary } from '/js/ui/asset-library.js';
      initAssetLibrary();

      import { initLedgerPanel } from '/js/ui/ledger-panel.js';
      initLedgerPanel();

      import { initSidebar } from '/js/ui/sidebar.js';
      initSidebar();

      import { initOutliner } from '/js/ui/outliner.js';
      initOutliner();

      import { initNesting } from "/js/ui/nesting.js";
      initNesting();

      document.addEventListener('wallet:connected', () => {
        const c = document.getElementById('connectWalletBtn');
        const d = document.getElementById('disconnectWalletBtn');
        if (c) { c.classList.add('hidden'); c.classList.remove('disconnected'); }
        if (d) d.classList.remove('hidden');
      });
      document.addEventListener('wallet:disconnected', () => {
        const c = document.getElementById('connectWalletBtn');
        const d = document.getElementById('disconnectWalletBtn');
        if (c) { c.classList.remove('hidden'); c.classList.add('disconnected'); }
        if (d) d.classList.add('hidden');
      });
