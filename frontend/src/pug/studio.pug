doctype html
html
  head
    title Arbesk Studio
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="icon", type="image/png", href="/logo.png")
    link(rel="apple-touch-icon", href="/apple-touch-icon.png")
    link(rel="stylesheet", href="/css/styles.css")
    script(src="https://cdn.babylonjs.com/babylon.js")
    script(src="https://cdn.babylonjs.com/loaders/babylonjs.loaders.min.js")
    script(src="https://cdn.jsdelivr.net/npm/web3@latest/dist/web3.min.js")
    script(src="https://cdn.jsdelivr.net/npm/web3modal@1.9.12/dist/index.js")
  body
    #app
      nav#topbar.arabesque-topbar
        .topbar-brand
          img.brand-icon(src="/logo.png", alt="Arbesk Logo")
          span.brand-text Arbesk
        #assetStatus.asset-status
          span#assetStatusName.asset-status-name No asset open
          span#assetStatusMeta.asset-status-meta Create or open an asset
        #assetHistory.asset-history-section(hidden)
          .history-bar
            .history-track-line
        .topbar-actions
          button#mobileMenuBtn.mobile-menu-toggle(aria-label="Toggle create panel")
            svg(width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
              line(x1="3" y1="6" x2="21" y2="6")
              line(x1="3" y1="12" x2="21" y2="12")
              line(x1="3" y1="18" x2="21" y2="18")
          button#newAssetTopBtn.btn-arabesque-secondary.btn-sm(title="Create a new asset") New Asset
          #saveAssetSection.topbar-save-section(hidden)
            button#saveAssetBtn.btn-arabesque-secondary.btn-sm
              svg.btn-icon(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
                path(d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2Z")
                path(d="M17 21v-8H7v8")
                path(d="M7 3v5h8")
              span#saveAssetBtnText Save Draft
            button#publishAssetBtn.btn-arabesque.btn-sm
              svg.btn-icon(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
                path(d="M12 3v12")
                path(d="m7 8 5-5 5 5")
                path(d="M5 15v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4")
              span#publishAssetBtnText Publish Asset
          button#connectWalletBtn.btn-arabesque-outline.btn-sm(onclick="connectWallet()") Connect Wallet
          button#disconnectWalletBtn.btn-arabesque-outline.btn-sm.hidden(onclick="disconnectWallet()") Disconnect

      .arabesque-lattice-border

      .studio-layout
        aside#chatSidebar.chat-sidebar
          .sidebar-header
            h3 Create
            button#toggleChatBtn.sidebar-toggle(aria-label="Collapse create panel")
              svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                polyline(points="15 18 9 12 15 6")
          .sidebar-body
            #assetDefinition.asset-definition-section
              .asset-def-header
                button#toggleAssetDef.asset-def-toggle(aria-label="Toggle settings")
                  svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                    polyline(points="9 18 15 12 9 6")
                  span Settings
              .asset-def-body(hidden)
                .control-group
                  label.form-label Asset Name
                  #assetNameDisplay.asset-name-display Untitled Asset
                .control-group
                  label.form-label(for="providerSelect") Generation Provider
                  select#providerSelect.form-select
                    option(value="mock") Mock (Local)
                    option(value="meshy") Meshy
                    option(value="tripo3d") Tripo3D
                    option(value="hunyuan3d") Hunyuan3D
                #teamPanel.team-section(hidden)
                  .team-header
                    h5 Asset Editors
                    span#teamOwnerBadge.owner-badge(hidden) Owner
                  #teamList.team-list
                  .team-add
                    input#teamAddInput.form-control(type="text", placeholder="0x… wallet address")
                    button#teamAddBtn.btn-arabesque.btn-sm Add Editor

            #chatHistory.chat-history
              .chat-welcome
                .welcome-icon ✦
                p.welcome-text Create an asset
                p.welcome-sub Describe the 3D asset you want to generate.

            #timeline.timeline-section(hidden)
              label.timeline-label Asset Variants
              .timeline-slider-wrap
                input#versionSlider.timeline-slider(type="range", min="0", max="0", step="1")
                span#versionLabel.version-badge v1

        button#showSidebarBtn.show-sidebar-btn(aria-label="Show create panel", title="Show create panel")
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            polyline(points="9 18 15 12 9 6")

        main#mainStage.main-stage
          #chatEditor.chat-editor
            .chat-editor-inner
              .editor-frame
                textarea#promptInput(placeholder="Describe the 3D asset you envision…")
                button#generateBtn.generate-btn(aria-label="Generate asset")
                  span.generate-icon ✦
                  span.generate-text Generate Asset

          #viewport.viewport
            canvas#renderCanvas

            #welcomeOverlay.welcome-overlay
              .welcome-content
                .welcome-icon-large ✦
                h2 Welcome to Arbesk
                p Create, compose, and publish tokenized 3D assets.
                .welcome-actions
                  button#newAssetBtn.btn-arabesque Start New Asset
                  p.welcome-hint Generate an asset, open one from your library, or drag an asset into the scene.

            #assetDropOverlay.asset-drop-overlay.hidden
              .asset-drop-content
                .asset-drop-icon ⊕
                p Drop to add linked asset to scene

            #waitingOverlay.waiting-overlay.hidden
              .waiting-content
                .arabesque-spinner
                p#waitingText.waiting-text Carving your asset…

          aside#inspector.inspector-panel(hidden)
            .inspector-header
              h5 Selection Inspector
              button.btn-close(type="button", aria-label="Close", onclick="document.getElementById('inspector').hidden=true")
            .inspector-body
              //- Token Child World Info (shown for child_ref nodes)
              #tokenChildInfo.inspector-token-child(hidden)
                .control-group
                  label.form-label Linked Token
                  span#tokenChildId.token-child-value —
                .control-group
                  label.form-label Contract
                  span#tokenChildContract.token-child-value —
                .control-group
                  label.form-label Chain ID
                  span#tokenChildChain.token-child-value —
                .control-group
                  label.form-label Resolution
                  span#tokenChildResolution.token-child-value latest
                .control-group
                  label.form-label Manifest CID
                  span#tokenChildCid.token-child-value.token-child-cid —
              //- Parametric Editor (shown for regular nodes)
              #parametricEditor
                .control-group
                  label.form-label(for="nodeColor") Color
                  input#nodeColor.form-control.form-control-color(type="color", value="#C19A6B")
                .control-group
                  label.form-label Scale X
                  input#nodeScaleX.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
                .control-group
                  label.form-label Scale Y
                  input#nodeScaleY.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
                .control-group
                  label.form-label Scale Z
                  input#nodeScaleZ.form-range(type="range", min="0.1", max="5", step="0.1", value="1")
                .control-actions
                  button#saveParametric.btn-arabesque Save Variant
                  button#cancelParametric.btn-arabesque-secondary Cancel

        aside#assetLibraryPanel.asset-library-panel.collapsed
          .asset-library-header
            h3 Asset Library
            button#assetLibraryToggle.asset-library-toggle(aria-label="Collapse asset library")
              svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                polyline(points="9 18 15 12 9 6")
          #assetLibraryBody.asset-library-body
            p.asset-library-empty Connect wallet to browse your asset tokens.

        button#showAssetLibraryBtn.show-asset-library-btn(aria-label="Show asset library", title="Show asset library", style="display:none")
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            polyline(points="15 18 9 12 15 6")

        //- Micro-Ledger Panel
        aside#ledgerPanel.ledger-panel.collapsed
          .ledger-panel-header
            h3 Audit Ledger
            button.ledger-panel-close.btn-close(type="button", aria-label="Close ledger")
          #ledgerBody.ledger-panel-body
            .ledger-panel-controls
              select#ledgerFilter.ledger-filter
                option(value="") All Operations
                option(value="GENERATION") Generation
                option(value="PARAMETRIC") Parametric
                option(value="SAVE") Save
                option(value="PUBLISH") Publish
                option(value="THUMBNAIL") Thumbnail
                option(value="MINT") Mint
                option(value="TOKEN_URI_UPDATE") URI Update
                option(value="TEAM_EDIT") Team Edit
              button#ledgerAnchorBtn.ledger-anchor-btn(
                title="Anchor current manifest CID on-chain for immutability proof"
              ) Anchor Manifest
            #ledgerStats.ledger-stats
            ul#ledgerList.ledger-list

        button#ledgerPanelToggle.ledger-panel-toggle(aria-label="Show audit ledger", title="Audit Ledger")
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z")
            path(d="M14 2v6h6")
            path(d="M8 13h2")
            path(d="M8 17h2")
            path(d="M14 13h2")
            path(d="M14 17h2")

    script(type="module", src="/js/engine/scene-graph.js")
    script(type="module", src="/js/engine/time-travel.js")
    script(type="module", src="/js/engine/parametric-preview.js")
    script(type="module", src="/js/blockchain/token-resolver.js")
    script(type="module", src="/js/blockchain/wallet.js")
    script(type="module", src="/js/services/api.js")
    script(type="module", src="/js/services/team.js")
    script(type="module", src="/js/ui/asset-editors.js")
    script(type="module", src="/js/ui/asset-library.js")
    script(type="module", src="/js/ui/asset-save.js")
    script(type="module", src="/js/ui/asset-history.js")
    script(type="module", src="/js/ui/create-panel.js")
    script(type="module", src="/js/ui/asset-drop-zone.js")
    script(type="module", src="/js/ui/ledger-panel.js")
    script(type="module").
      import { initAssetLibrary } from '/js/ui/asset-library.js';
      initAssetLibrary();

      import { initLedgerPanel } from '/js/ui/ledger-panel.js';
      initLedgerPanel();

      document.addEventListener('wallet:connected', () => {
        document.getElementById('connectWalletBtn').classList.add('hidden');
        document.getElementById('disconnectWalletBtn').classList.remove('hidden');
      });
      document.addEventListener('wallet:disconnected', () => {
        document.getElementById('connectWalletBtn').classList.remove('hidden');
        document.getElementById('disconnectWalletBtn').classList.add('hidden');
      });
