    script.
      (function () {
        // Modern browsers animate reveals + parallax purely in CSS via
        // animation-timeline; nothing to do here in that case.
        if (window.CSS && CSS.supports && CSS.supports('animation-timeline: view()')) {
          return;
        }

        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('revealed');
          });
          return;
        }

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.15,
          rootMargin: '0px 0px -50px 0px'
        });

        document.querySelectorAll('.reveal').forEach(function (el) {
          observer.observe(el);
        });
      })();

    script.
      // Lazy Babylon viewers — booted only when scrolled into view, sharing a
      // single CDN load between the Howdy model and the colour-memory cube.
      (function () {
        if (!('IntersectionObserver' in window)) return;

        // Minified core comes from jsDelivr (cdn.babylonjs.com only ships the
        // unminified build at versioned paths); loaders stay on the BJS CDN.
        var BJS_CORE = 'https://cdn.jsdelivr.net/npm/babylonjs@9.12.0/babylon.min.js';
        var BJS = 'https://cdn.babylonjs.com/v9.12.0/';
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var coreP = null, loadersP = null;

        function loadScript(src) {
          return new Promise(function (resolve, reject) {
            var s = document.createElement('script');
            s.src = src;
            s.crossOrigin = 'anonymous';
            s.onload = resolve;
            s.onerror = reject;
            document.head.appendChild(s);
          });
        }
        function ensureCore() {
          if (!coreP) coreP = loadScript(BJS_CORE);
          return coreP;
        }
        function ensureLoaders() {
          if (!loadersP) loadersP = ensureCore().then(function () {
            return loadScript(BJS + 'loaders/babylonjs.loaders.min.js');
          });
          return loadersP;
        }

        // Boot `setup(canvas)` the first time `canvas` scrolls into view, then
        // pause/resume its render loop as it leaves/enters the viewport.
        function lazyViewer(canvas, setup) {
          var state = null, booting = false;
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (state) { state.start(); }
                else if (!booting) {
                  booting = true;
                  setup(canvas).then(function (s) { state = s; if (s) s.start(); });
                }
              } else if (state) {
                state.stop();
              }
            });
          }, { threshold: 0.2 });
          io.observe(canvas);
        }

        function loopController(engine, render) {
          return {
            start: function () { engine.stopRenderLoop(); engine.runRenderLoop(render); },
            stop: function () { engine.stopRenderLoop(); }
          };
        }

        // ─── Live Howdy model viewer ───────────────────────────────────────
        var heroCanvas = document.getElementById('hero-viewer');
        if (heroCanvas) {
          lazyViewer(heroCanvas, async function (canvas) {
            var card = canvas.closest('.viewer-card');
            try {
              await ensureLoaders();
            } catch (e) { card.classList.add('viewer-failed'); return null; }

            var engine = new BABYLON.Engine(canvas, true, { alpha: true, antialias: true });
            var scene = new BABYLON.Scene(engine);
            scene.clearColor = new BABYLON.Color4(0, 0, 0, 0);

            var result;
            try {
              result = await BABYLON.SceneLoader.ImportMeshAsync('', '/models/', 'howdy.glb', scene);
            } catch (e) { card.classList.add('viewer-failed'); engine.dispose(); return null; }

            var min = new BABYLON.Vector3(Infinity, Infinity, Infinity);
            var max = new BABYLON.Vector3(-Infinity, -Infinity, -Infinity);
            result.meshes.forEach(function (m) {
              if (!m.getTotalVertices || m.getTotalVertices() === 0) return;
              var b = m.getBoundingInfo().boundingBox;
              min = BABYLON.Vector3.Minimize(min, b.minimumWorld);
              max = BABYLON.Vector3.Maximize(max, b.maximumWorld);
            });
            var center = min.add(max).scale(0.5);
            var radius = max.subtract(min).length() / 2 || 1;

            var camera = new BABYLON.ArcRotateCamera('cam', Math.PI / 4, Math.PI / 2.6, radius * 2.8, center, scene);
            camera.fov = 0.5;
            camera.lowerRadiusLimit = radius * 1.7;
            camera.upperRadiusLimit = radius * 4;
            camera.lowerBetaLimit = 0.6;
            camera.upperBetaLimit = Math.PI / 1.9;
            camera.wheelPrecision = 40;
            camera.panningSensibility = 0;
            camera.attachControl(canvas, true);

            var key = new BABYLON.HemisphericLight('key', new BABYLON.Vector3(0.3, 1, 0.2), scene);
            key.intensity = 0.95;
            var rim = new BABYLON.DirectionalLight('rim', new BABYLON.Vector3(-0.6, -0.2, 1), scene);
            rim.intensity = 1.4;
            rim.diffuse = new BABYLON.Color3(0.63, 0.47, 0.28);
            var fill = new BABYLON.DirectionalLight('fill', new BABYLON.Vector3(0.5, -0.5, -0.5), scene);
            fill.intensity = 0.4;

            var spinning = true;
            canvas.addEventListener('pointerdown', function () { spinning = false; });
            card.classList.add('viewer-ready');

            return loopController(engine, function () {
              engine.resize();
              if (spinning && !reduce) camera.alpha += 0.0035;
              scene.render();
            });
          });
        }

        // ─── Time-travelling colour-memory cube ───────────────────────────
        // Click the cube to append a new version; drag the scrubber to travel
        // back through every colour the object has ever been.
        var cubeCanvas = document.getElementById('memory-cube');
        if (cubeCanvas) {
          var COLORS = [
            { name: 'blue',   hex: '#3b6ea5' },
            { name: 'green',  hex: '#4a8c5a' },
            { name: 'amber',  hex: '#c08a3e' },
            { name: 'crimson', hex: '#b3432f' },
            { name: 'violet', hex: '#6a4a8c' },
            { name: 'teal',   hex: '#2f8c8c' }
          ];
          var byName = {};
          COLORS.forEach(function (c) { byName[c.name] = c; });

          // versions[] runs oldest → newest. Seed a little history so the
          // timeline is meaningful before the visitor touches anything.
          var now = Date.now();
          var versions = [
            { name: 'amber', at: now - 12 * 60 * 1000 },
            { name: 'blue',  at: now - 5 * 60 * 1000 },
            { name: 'green', at: now }
          ];
          var selected = versions.length - 1; // index currently displayed

          var logEl = document.querySelector('.memory-log');
          var statusEl = document.querySelector('.memory-status');
          var scrub = document.getElementById('memory-scrub');
          var memCard = cubeCanvas.closest('.memory-card');
          var view = null; // assigned once the Babylon cube boots: { setColor(hex) }

          function relTime(at) {
            var s = Math.round((Date.now() - at) / 1000);
            if (s < 5) return 'just now';
            if (s < 60) return s + 's ago';
            var m = Math.round(s / 60);
            if (m < 60) return m + ' min ago';
            return Math.round(m / 60) + 'h ago';
          }
          function swatch(name) {
            return '<span class="swatch" style="background:' + byName[name].hex + '"></span>';
          }
          function syncSlider() {
            if (!scrub) return;
            scrub.max = String(versions.length - 1);
            scrub.value = String(selected);
          }
          function renderStatus() {
            if (!statusEl) return;
            var v = versions[selected];
            var latest = selected === versions.length - 1;
            if (latest) {
              statusEl.innerHTML = '<strong>Latest version</strong> — ' +
                v.name + ' · ' + relTime(v.at);
            } else {
              statusEl.innerHTML = '<span class="past-flag">Past version ' +
                (selected + 1) + ' of ' + versions.length + '</span> — I was <strong>' +
                v.name + '</strong> · ' + relTime(v.at);
            }
          }
          function renderLog() {
            if (!logEl) return;
            var html = '';
            for (var i = versions.length - 1; i >= 0; i--) {
              var v = versions[i];
              var cls = [];
              if (i === versions.length - 1) cls.push('now');
              if (i === selected) cls.push('active');
              var label = (i === versions.length - 1) ? 'Now — ' + v.name : 'I was ' + v.name;
              html += '<li class="' + cls.join(' ') + '">' + swatch(v.name) +
                '<span>' + label + '</span>' +
                '<span class="when">' + relTime(v.at) + '</span></li>';
            }
            logEl.innerHTML = html;
          }
          function applyColor() {
            if (view) view.setColor(byName[versions[selected].name].hex);
          }
          function selectIndex(i) {
            selected = Math.max(0, Math.min(versions.length - 1, parseInt(i, 10) || 0));
            syncSlider();
            applyColor();
            renderStatus();
            renderLog();
          }
          function paint() {
            var last = versions[versions.length - 1].name;
            var next;
            do { next = COLORS[Math.floor(Math.random() * COLORS.length)]; }
            while (next.name === last);
            versions.push({ name: next.name, at: Date.now() });
            if (versions.length > 8) versions.shift();
            memCard.classList.add('touched');
            selectIndex(versions.length - 1); // jump to the freshly-painted version
          }

          if (scrub) {
            scrub.addEventListener('input', function () {
              memCard.classList.add('touched');
              selectIndex(scrub.value);
            });
          }

          // Initial paint of slider + status + log (works before the cube boots).
          syncSlider();
          renderStatus();
          renderLog();

          lazyViewer(cubeCanvas, async function (canvas) {
            try { await ensureCore(); } catch (e) { return null; }

            var engine = new BABYLON.Engine(canvas, true, { alpha: true, antialias: true });
            var scene = new BABYLON.Scene(engine);
            scene.clearColor = new BABYLON.Color4(0, 0, 0, 0);

            var camera = new BABYLON.ArcRotateCamera('cam', Math.PI / 4, Math.PI / 2.7, 4.2, BABYLON.Vector3.Zero(), scene);
            camera.fov = 0.5;
            camera.lowerRadiusLimit = 3;
            camera.upperRadiusLimit = 6;
            camera.lowerBetaLimit = 0.5;
            camera.upperBetaLimit = Math.PI / 1.9;
            camera.wheelPrecision = 60;
            camera.panningSensibility = 0;
            camera.attachControl(canvas, true);

            var key = new BABYLON.HemisphericLight('key', new BABYLON.Vector3(0.3, 1, 0.4), scene);
            key.intensity = 0.9;
            var rim = new BABYLON.DirectionalLight('rim', new BABYLON.Vector3(-0.6, -0.3, 1), scene);
            rim.intensity = 1.1;
            rim.diffuse = new BABYLON.Color3(0.63, 0.47, 0.28);

            var cube = BABYLON.MeshBuilder.CreateBox('cube', { size: 1.7 }, scene);
            var mat = new BABYLON.StandardMaterial('cubeMat', scene);
            mat.specularColor = new BABYLON.Color3(0.25, 0.25, 0.25);
            cube.material = mat;
            var target = BABYLON.Color3.FromHexString(byName[versions[selected].name].hex);
            mat.diffuseColor = target.clone();

            // Expose a colour setter so scrub/paint can drive the live cube.
            view = { setColor: function (hex) { target = BABYLON.Color3.FromHexString(hex); } };

            var downX = 0, downY = 0, spinning = true;
            canvas.addEventListener('pointerdown', function (e) { downX = e.clientX; downY = e.clientY; spinning = false; });
            canvas.addEventListener('pointerup', function (e) {
              if (Math.abs(e.clientX - downX) + Math.abs(e.clientY - downY) < 8) paint();
            });

            memCard.classList.add('ready');

            return loopController(engine, function () {
              engine.resize();
              if (spinning && !reduce) camera.alpha += 0.0028;
              mat.diffuseColor = BABYLON.Color3.Lerp(mat.diffuseColor, target, 0.18);
              scene.render();
            });
          });
        }
      })();
