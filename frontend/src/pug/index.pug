doctype html
html(lang="en")
  head
    title Arbesk — 4D Version-Controlled 3D Assets
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    meta(name="description", content="Arbesk is a 4D 3D-asset platform: generate, edit, and publish 3D worlds where every past version stays open-able. Time is a dimension you can travel — but only backward.")
    meta(property="og:title", content="Arbesk — 4D Version-Controlled 3D Assets")
    meta(property="og:description", content="Generate, edit, and publish 3D worlds with built-in version history. Every asset is its own micro-ledger.")
    meta(property="og:type", content="website")
    meta(property="og:site_name", content="Arbesk")
    meta(name="twitter:card", content="summary_large_image")
    //- TODO: add og:image, og:url, and rel=canonical once the production
    //- domain is fixed — those tags require absolute URLs.
    link(rel="icon", type="image/webp", href="/logo.webp")
    link(rel="apple-touch-icon", href="/apple-touch-icon.webp")
    link(rel="stylesheet", href="/css/styles.css")
    script(src="/js/engine/theme-init.js")
    script.
      document.documentElement.classList.add('js-animations');
    style.
      :root {
        --landing-bg: var(--choco-1, #faf6f2);
        --landing-fg: var(--choco-12, #2a1a0e);
        --landing-muted: var(--choco-7, #8c6a4a);
        --landing-gold: var(--gold, #a07848);
        --landing-gold-strong: var(--gold-6, #8c673c); /* ≥4.5:1 with white text */
        --landing-card: var(--choco-2, #f0e6d8);
        --landing-border: var(--choco-5, #b89a7a);
        --landing-dark: var(--choco-12, #2a1a0e);
      }

      html:has(.landing-page),
      .landing-page,
      .landing-page body {
        overflow: auto;
        height: auto;
      }

      .landing-page #app {
        height: auto;
        min-height: 100vh;
        overflow: visible;
      }

      .landing-page {
        background: var(--landing-bg);
        color: var(--landing-fg);
        line-height: 1.6;
      }

      /* Header */
      .landing-page .headerbar {
        position: sticky;
        top: 0;
        z-index: 100;
        background: color-mix(in srgb, var(--landing-bg) 92%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid color-mix(in srgb, var(--landing-border) 30%, transparent);
      }

      /* Brand: scalable mark + wordmark */
      .landing-page .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        color: var(--landing-gold);
      }

      .landing-page .brand-mark {
        height: 2.7rem;
        width: auto;
        flex: none;
      }

      .landing-page .brand-name {
        font-size: 1.45rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--landing-fg);
      }

      /* Typography */
      .landing-hero h1 {
        font-size: clamp(3.5rem, 10vw, 7rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 0.95;
        margin: 0 0 1.25rem;
      }

      .landing-section .text h2 {
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin: 0 0 1rem;
      }

      .landing-section .text p {
        font-size: 1.15rem;
        color: var(--landing-muted);
        margin: 0;
        max-width: 38ch;
      }

      /* Layout shells */
      .landing-hero,
      .landing-section,
      .landing-footer {
        width: 100%;
        margin: 0 auto;
        padding: 7rem 2rem;
      }

      .landing-section.band-dark,
      .landing-section.pull-quote {
        max-width: none;
      }

      .landing-hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .landing-hero .lead {
        font-size: clamp(1.1rem, 2.4vw, 1.35rem);
        color: var(--landing-muted);
        max-width: 560px;
        margin: 0 auto 2.5rem;
      }

      .landing-hero .lead strong {
        color: var(--landing-gold);
      }

      /* CTA */
      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--landing-gold-strong);
        color: #fff;
        padding: 0.95rem 2.25rem;
        border-radius: 999px;
        font-weight: 600;
        text-decoration: none;
        font-size: 1rem;
        box-shadow: 0 4px 20px rgba(160,120,72,0.35);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }

      .cta:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(160,120,72,0.45);
      }

      .cta svg {
        transition: transform 0.25s ease;
      }

      .cta:hover svg {
        transform: translateX(4px);
      }

      .cta-row {
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .cta-secondary {
        background: transparent;
        color: var(--landing-gold-strong);
        box-shadow: none;
        border: 1.5px solid color-mix(in srgb, var(--landing-gold) 55%, transparent);
      }

      .cta-secondary:hover {
        background: color-mix(in srgb, var(--landing-gold) 12%, transparent);
        box-shadow: 0 6px 18px rgba(160,120,72,0.18);
      }

      /* Feature sections */
      .landing-section {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 4rem;
        align-items: center;
        max-width: 1180px;
      }

      .landing-section.reverse {
        grid-template-columns: 0.85fr 1.15fr;
      }

      .landing-section.reverse .text {
        order: 2;
      }

      .landing-section.reverse .visual {
        order: 1;
      }

      .feature-card {
        position: relative;
        background: var(--landing-card);
        border: 1px solid color-mix(in srgb, var(--landing-border) 40%, transparent);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 12px 40px rgba(42, 26, 14, 0.06);
      }

      .landing-section .visual {
        display: grid;
        place-items: center;
        min-height: 240px;
      }

      /* Grid items default to min-width:auto, which lets fixed-width cards
         (viewer, memory) force the track past the viewport on phones. */
      .landing-section .text,
      .landing-section .visual {
        min-width: 0;
      }

      /* Real-render visuals fill their frame */
      .asset-render {
        display: block;
        width: 100%;
        height: auto;
        filter: drop-shadow(0 18px 30px rgba(42, 26, 14, 0.18));
      }

      /* Live 3D viewer */
      .viewer-card {
        position: relative;
        width: min(420px, 100%);
        aspect-ratio: 1 / 1;
        max-width: 100%;
        border-radius: 28px;
        background:
          radial-gradient(120% 120% at 50% 20%,
            color-mix(in srgb, var(--landing-gold) 16%, transparent),
            transparent 60%),
          var(--landing-card);
        border: 1px solid color-mix(in srgb, var(--landing-border) 40%, transparent);
        box-shadow: 0 20px 50px rgba(42, 26, 14, 0.12);
        overflow: hidden;
      }

      .viewer-card canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        outline: none;
        touch-action: pan-y;
        opacity: 0;
        transition: opacity 0.6s ease;
      }

      .viewer-card.viewer-ready canvas {
        opacity: 1;
      }

      .viewer-card .viewer-hint {
        position: absolute;
        left: 50%;
        bottom: 0.9rem;
        transform: translateX(-50%);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--landing-muted);
        background: color-mix(in srgb, var(--landing-bg) 80%, transparent);
        padding: 0.25rem 0.7rem;
        border-radius: 999px;
        opacity: 0;
        transition: opacity 0.6s ease 0.3s;
        pointer-events: none;
      }

      .viewer-card.viewer-ready .viewer-hint {
        opacity: 1;
      }

      /* The static render shows immediately and crossfades out once the live
         viewer boots, so fast scrollers never see an empty card. */
      .viewer-card .viewer-fallback {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        opacity: 1;
        transition: opacity 0.6s ease;
      }

      .viewer-card.viewer-ready .viewer-fallback {
        opacity: 0;
        pointer-events: none;
      }

      .viewer-card.viewer-failed canvas,
      .viewer-card.viewer-failed .viewer-hint {
        display: none;
      }

      .viewer-card.viewer-failed .viewer-fallback {
        display: grid;
      }

      .viewer-card .viewer-fallback img {
        width: 88%;
        height: auto;
      }

      /* Interactive colour-memory demo ("Objects have memory") */
      .text .hint-line {
        margin-top: 0.75rem;
        font-size: 0.95rem;
        color: color-mix(in srgb, var(--landing-gold) 85%, var(--landing-fg));
      }

      .memory-card {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: min(360px, 100%);
        max-width: 100%;
        margin: 0 auto;
      }

      .memory-stage {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 3;
        border-radius: 18px;
        overflow: hidden;
        background:
          radial-gradient(120% 120% at 50% 25%,
            color-mix(in srgb, var(--landing-gold) 14%, transparent),
            transparent 60%);
        cursor: pointer;
      }

      .memory-stage canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        outline: none;
        touch-action: pan-y;
        opacity: 0;
        transition: opacity 0.5s ease;
      }

      .memory-card.ready .memory-stage canvas { opacity: 1; }

      .memory-stage .memory-hint {
        position: absolute;
        left: 50%;
        bottom: 0.7rem;
        transform: translateX(-50%);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--landing-muted);
        background: color-mix(in srgb, var(--landing-bg) 80%, transparent);
        padding: 0.22rem 0.65rem;
        border-radius: 999px;
        pointer-events: none;
        transition: opacity 0.4s ease;
      }

      .memory-card.touched .memory-stage .memory-hint { opacity: 0; }

      .memory-stage .memory-fallback {
        display: grid;
        position: absolute;
        inset: 0;
        margin: 0;
        place-content: center;
        text-align: center;
        padding: 1.5rem;
        color: var(--landing-muted);
        font-size: 0.95rem;
        opacity: 1;
        transition: opacity 0.5s ease;
      }

      .memory-card.ready .memory-stage .memory-fallback {
        opacity: 0;
        pointer-events: none;
      }

      .memory-controls {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .memory-controls input[type="range"] {
        width: 100%;
        accent-color: var(--landing-gold);
        cursor: pointer;
      }

      .memory-status {
        margin: 0;
        font-size: 0.9rem;
        color: var(--landing-muted);
        min-height: 1.3em;
      }

      .memory-status strong {
        color: var(--landing-fg);
      }

      .memory-status .past-flag {
        color: var(--landing-gold);
        font-weight: 600;
      }

      .memory-log {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-height: 5.5rem;
      }

      .memory-log li.active {
        color: var(--landing-fg);
        font-weight: 600;
      }

      .memory-log li.active .swatch {
        outline: 2px solid var(--landing-gold);
        outline-offset: 1px;
      }

      .memory-log li {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        font-size: 0.95rem;
        color: var(--landing-muted);
      }

      .memory-log li.now {
        color: var(--landing-fg);
        font-weight: 600;
      }

      .memory-log .swatch {
        width: 1.05rem;
        height: 1.05rem;
        border-radius: 5px;
        flex: none;
        border: 1px solid color-mix(in srgb, var(--landing-fg) 18%, transparent);
        box-shadow: 0 2px 6px rgba(42,26,14,0.12);
      }

      .memory-log li.now .swatch {
        width: 1.3rem;
        height: 1.3rem;
      }

      .memory-log .when {
        margin-left: auto;
        font-size: 0.82rem;
        color: color-mix(in srgb, var(--landing-muted) 80%, transparent);
      }

      /* Version timeline ("Time is a dimension") */
      .timeline {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: clamp(1.5rem, 6vw, 3.5rem);
        width: 100%;
        padding: 1rem 0.5rem;
        position: relative;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 8%;
        right: 8%;
        bottom: 2.1rem;
        height: 2px;
        background: color-mix(in srgb, var(--landing-gold) 55%, transparent);
      }

      .timeline .stop {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
      }

      .timeline .stop .dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--landing-gold);
        position: relative;
        z-index: 1;
      }

      .timeline .stop .label {
        font-size: 0.85rem;
        font-weight: 700;
        color: color-mix(in srgb, var(--landing-bg) 75%, transparent);
      }

      .timeline .stop.active .thumb {
        width: clamp(74px, 16vw, 104px);
        height: clamp(74px, 16vw, 104px);
        border-radius: 18px;
        background: color-mix(in srgb, var(--landing-bg) 10%, transparent);
        border: 2px solid var(--landing-gold);
        display: grid;
        place-items: center;
        box-shadow: 0 12px 28px rgba(0,0,0,0.25);
      }

      .timeline .stop.active .thumb img {
        width: 86%;
        height: 86%;
        object-fit: contain;
      }

      .timeline .stop.active .dot {
        width: 18px;
        height: 18px;
        background: var(--landing-bg);
        border: 3px solid var(--landing-gold);
      }

      /* Manifest chain ("micro-ledger") */
      .ledger-card .ledger-chain {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        flex-wrap: nowrap;
      }

      .ledger-chain .manifest {
        flex: 1 1 0;
        min-width: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.45rem;
        background: color-mix(in srgb, var(--landing-bg) 60%, transparent);
        border: 1.5px solid color-mix(in srgb, var(--landing-gold) 60%, transparent);
        border-radius: 14px;
        padding: 1rem 0.4rem;
      }

      .ledger-chain .manifest .mtag {
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--landing-fg);
        letter-spacing: -0.01em;
      }

      .ledger-chain .manifest .cid {
        font-family: ui-monospace, "SF Mono", Menlo, monospace;
        font-size: 0.68rem;
        color: var(--landing-muted);
      }

      .ledger-chain .link {
        flex: none;
        width: 18px;
        height: 2px;
        background: var(--landing-gold);
        opacity: 0.6;
      }

      .ledger-card .ledger-caption {
        margin-top: 1.1rem;
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--landing-muted);
      }

      /* Collaboration ("Built for teams") — three pedestals, one per editor */
      .team-card .team-scene {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        max-width: 420px;
        margin: 0 auto;
        padding-top: 1rem;
      }

      .team-scene .pedestal {
        flex: 1 1 0;
        min-width: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      /* Stagger the middle pedestal up so the trio reads like a podium. */
      .team-scene .pedestal:nth-child(2) { margin-bottom: 1.6rem; }

      .team-scene .pedestal-asset {
        width: 100%;
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: end center;
      }

      .team-scene .pedestal-asset img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 12px 18px rgba(42,26,14,0.22));
      }

      .team-scene .pedestal-base {
        width: 86%;
        height: 0.85rem;
        border-radius: 4px 4px 6px 6px;
        background:
          linear-gradient(180deg,
            color-mix(in srgb, var(--landing-gold) 32%, var(--landing-card)) 0%,
            color-mix(in srgb, var(--landing-gold) 14%, var(--landing-card)) 100%);
        border: 1px solid color-mix(in srgb, var(--landing-gold) 45%, transparent);
        box-shadow: 0 8px 16px rgba(42,26,14,0.16);
        margin-top: -0.2rem;
      }

      .team-scene .pedestal-label {
        margin-top: 0.6rem;
        font-size: 0.78rem;
        line-height: 1.3;
        color: var(--landing-muted);
        display: flex;
        flex-direction: column;
      }

      .team-scene .pedestal-label strong {
        color: var(--landing-fg);
        font-size: 0.92rem;
      }

      /* Dark bands — clean straight edges with a gold rule at each boundary */
      .band-dark {
        background: var(--landing-dark);
        color: var(--landing-bg);
        border-top: 1px solid color-mix(in srgb, var(--landing-gold) 22%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--landing-gold) 22%, transparent);
      }

      .band-dark .text h2 {
        color: var(--landing-gold);
      }

      .band-dark .text p {
        color: color-mix(in srgb, var(--landing-bg) 80%, transparent);
      }

      .band-dark .cta {
        background: var(--landing-gold-strong);
        color: #fff;
      }

      /* Pull quote */
      .pull-quote {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 70vh;
        padding: 7rem 2rem;
      }

      .pull-quote .quote-mark {
        font-size: 5rem;
        line-height: 0.8;
        color: var(--landing-gold);
        opacity: 0.5;
        margin-bottom: 0.5rem;
      }

      .pull-quote blockquote {
        font-size: clamp(2.5rem, 7vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.05;
        margin: 0 auto 1.25rem;
        max-width: 1100px;
        color: var(--landing-gold);
      }

      .pull-quote p {
        color: color-mix(in srgb, var(--landing-bg) 75%, transparent);
        font-size: 1.15rem;
        max-width: 560px;
        margin: 0 auto;
      }

      /* Footer */
      .landing-footer {
        text-align: center;
        padding: 7rem 2rem 6rem;
      }

      .landing-footer h2 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 700;
        margin: 0 0 1.5rem;
        color: var(--landing-bg);
      }


      /* ── Scroll-driven reveals & parallax ──────────────────────────────
         Modern path  — CSS animation-timeline: view() (Chrome 115+, FF 110+)
           · Headings  slide in from their outside edge (left on normal, right on
             .reverse sections) — distinctly horizontal, not the old "fade up".
           · Body text fades in cleanly, no vertical jump.
           · Visual cards lift and scale (0.93→1) as they enter.
           · Visual column drifts against text via a subtle parallax on cover.
           · animation-range ends before entry 65%, so nothing is ever stuck
             half-faded — all elements are fully visible once mostly in view.
         Fallback path — JS IntersectionObserver toggles .revealed for browsers
           without scroll-timeline support (unchanged behaviour, IO bails out
           when @supports passes).
      */

      /* No-JS / SSR baseline: always readable. */
      .reveal .reveal-child-1,
      .reveal .reveal-child-2,
      .reveal .reveal-child-3 { opacity: 1; translate: none; scale: 1; }

      /* Fallback: IO path. */
      .js-animations .reveal .reveal-child-1,
      .js-animations .reveal .reveal-child-2,
      .js-animations .reveal .reveal-child-3 {
        opacity: 0;
        translate: 0 28px;
        transition: opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1),
                    translate 0.75s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .js-animations .reveal.revealed .reveal-child-1 { opacity: 1; translate: none; transition-delay: 0s; }
      .js-animations .reveal.revealed .reveal-child-2 { opacity: 1; translate: none; transition-delay: 0.12s; }
      .js-animations .reveal.revealed .reveal-child-3 { opacity: 1; translate: none; transition-delay: 0.26s; }

      /* Hero entrance — time-based, not scroll-driven. */
      .hero-animate { opacity: 1; transform: none; }
      .js-animations .hero-animate {
        opacity: 0;
        transform: translateY(36px);
        animation: kHeroIn 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      .js-animations .hero-animate:nth-child(1) { animation-delay: 0.1s; }
      .js-animations .hero-animate:nth-child(2) { animation-delay: 0.25s; }
      .js-animations .hero-animate:nth-child(3) { animation-delay: 0.4s; }
      @keyframes kHeroIn { to { opacity: 1; transform: none; } }

      /* Keyframes — using individual transform properties (translate, scale) so
         they compose cleanly with kParallax which uses transform: translateY(). */
      @keyframes kSlideLeft  {
        from { opacity: 0; translate: -48px 0; }
        to   { opacity: 1; translate: 0 0; }
      }
      @keyframes kSlideRight {
        from { opacity: 0; translate: 48px 0; }
        to   { opacity: 1; translate: 0 0; }
      }
      @keyframes kFadeRise {
        from { opacity: 0; translate: 0 18px; }
        to   { opacity: 1; translate: 0 0; }
      }
      @keyframes kCardLift {
        from { opacity: 0; scale: 0.92; translate: 0 20px; }
        to   { opacity: 1; scale: 1;    translate: 0 0; }
      }
      @keyframes kParallax {
        from { transform: translateY(26px); }
        to   { transform: translateY(-26px); }
      }

      @supports (animation-timeline: view()) {
        /* All ranges end by entry 36% so even footer elements (which can't be
           scrolled past) are fully visible at the page's maximum scroll position. */

        /* Child-1: section headings slide in from the outside column edge. */
        .js-animations .landing-section:not(.pull-quote) h2.reveal-child-1 {
          opacity: 0; transition: none;
          animation: kSlideLeft 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 28%;
          will-change: opacity, translate;
        }
        .js-animations .landing-section.reverse:not(.pull-quote) h2.reveal-child-1 {
          opacity: 0; transition: none;
          animation: kSlideRight 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 28%;
          will-change: opacity, translate;
        }
        /* Child-1 for all other contexts (pull-quote mark, footer h2): fade-rise. */
        .js-animations .reveal .reveal-child-1 {
          opacity: 0; transition: none;
          animation: kFadeRise 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 28%;
          will-change: opacity, translate;
        }

        /* Child-2: body text, staggered slightly after child-1. */
        .js-animations .reveal .reveal-child-2 {
          opacity: 0; transition: none;
          animation: kFadeRise 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 5% entry 33%;
          will-change: opacity, translate;
        }

        /* Child-3 default: fade-rise (pull-quote body text, footer links). */
        .js-animations .reveal .reveal-child-3 {
          opacity: 0; transition: none;
          animation: kFadeRise 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 8% entry 36%;
          will-change: opacity, translate;
        }
        /* Child-3 for visual cards: scale lift + simultaneous parallax drift. */
        .js-animations .landing-section .visual.reveal-child-3 {
          opacity: 0; transition: none;
          animation: kCardLift 0.7s cubic-bezier(0.22, 1, 0.36, 1) both,
                     kParallax linear both;
          animation-timeline: view(), view();
          animation-range: entry 8% entry 36%, cover 0% cover 100%;
          will-change: opacity, translate, scale, transform;
        }
      }

      /* Keep the sticky header a single row on phones: the logo mark alone
         identifies the brand, freeing room for the tabs + Launch Studio. */
      @media (max-width: 520px) {
        .landing-page .brand-name {
          display: none;
        }

        .landing-page .headerbar {
          padding: 0 var(--size-2, 0.5rem);
        }
      }

      @media (max-width: 860px) {
        .landing-section,
        .landing-section.reverse {
          grid-template-columns: 1fr;
          gap: 2.5rem;
          text-align: center;
        }

        .landing-section .text p {
          max-width: none;
          margin: 0 auto;
        }

        .landing-section.reverse .text,
        .landing-section.reverse .visual,
        .landing-section .visual {
          order: 0;
        }

        .landing-section .visual {
          order: -1;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal .reveal-child-1,
        .reveal .reveal-child-2,
        .reveal .reveal-child-3,
        .js-animations .reveal .reveal-child-1,
        .js-animations .reveal .reveal-child-2,
        .js-animations .reveal .reveal-child-3,
        .js-animations .landing-section .visual.reveal-child-3,
        .hero-animate,
        .js-animations .hero-animate {
          animation: none !important;
          opacity: 1 !important;
          translate: none !important;
          transform: none !important;
          scale: 1 !important;
          transition: none !important;
        }

        .cta,
        .cta svg {
          transition: none;
        }

        .cta:hover {
          transform: none;
        }

        .cta:hover svg {
          transform: none;
        }
      }

    noscript
      style.
        .reveal .reveal-child-1,
        .reveal .reveal-child-2,
        .reveal .reveal-child-3,
        .hero-animate {
          opacity: 1;
          transform: none;
          translate: none;
          scale: 1;
          animation: none;
        }
        /* Without JS the live viewer never boots — show its render instead. */
        .viewer-card canvas,
        .viewer-card .viewer-hint { display: none; }
        .viewer-card .viewer-fallback { display: grid; }
        /* The colour-memory cube also needs JS — show a static line instead. */
        .memory-stage canvas,
        .memory-stage .memory-hint,
        .memory-log { display: none; }
        .memory-stage .memory-fallback { display: grid; }

