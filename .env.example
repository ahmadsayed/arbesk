# Backend API / IPFS
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs/

# EVM RPC (Hardhat local default)
API_URL=http://127.0.0.1:8545
HARDHAT_RPC_URL=http://127.0.0.1:8545

# ArbeskAssetFree (free tier) — default contract
CONTRACT_ADDRESS=

# ArbeskAsset (paid tier)
PAID_CONTRACT_ADDRESS=

# Nostr relay used by the chat proxy
NOSTR_RELAY_URL=ws://127.0.0.1:7777

# Nostr service private key (32-byte hex) used by the chat proxy to sign events.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOSTR_SERVICE_PRIVATE_KEY=

# Optional: WalletConnect project id for the frontend
WALLETCONNECT_PROJECT_ID=

# Optional: mock 3D generation for development
MOCK_3D_GENERATION=false
