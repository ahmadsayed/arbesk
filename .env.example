# Smart contract addresses (sync from blockchain/.env after deploy)
CONTRACT_ADDRESS=
PAID_CONTRACT_ADDRESS=
USDC_TOKEN=
BASE_CONTRACT_ADDRESS=

# IPFS storage backend: "pinata" (dev/prod) or "kubo" (automated E2E only)
IPFS_BACKEND=kubo

# Kubo settings (used when IPFS_BACKEND=kubo)
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs/

# Pinata settings (used when IPFS_BACKEND=pinata)
# PINATA_JWT is server-only — never expose it to the browser.
PINATA_JWT=
PINATA_GATEWAY=your-gateway.mypinata.cloud
PINATA_UPLOAD_TTL=60

# Pre-minted credential pool (hides Pinata's /files/sign latency from the
# upload-url request path). 0 disables pooling. PINATA_UPLOAD_TTL must
# comfortably exceed PINATA_POOL_EXPIRY_MARGIN or pooled credentials expire
# before they can be served — see arbesk-ipfs-storage skill, Pinata Mode §7.
PINATA_POOL_SIZE=20
PINATA_POOL_EXPIRY_MARGIN=60

# Nostr relay used by the chat proxy
NOSTR_RELAY_URL=ws://127.0.0.1:7777

# Nostr service private key (32-byte hex) used by the chat proxy to sign events.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOSTR_SERVICE_PRIVATE_KEY=

# Local dev
HARDHAT_RPC_URL=http://127.0.0.1:8545
MOCK_3D_GENERATION=true

# Tripo3D model version used by the backend adapter. Default: v2.5-20250123
TRIPO_3D_MODEL=v2.5-20250123

# Tripo3D API key for local manual/integration testing only.
# The production UI uses BYOK (providerKey) per request; the backend never reads this key.
TRIPO_3D_KEY=

# ─── CDP / Base (email login + gasless) ───
# CDP Project ID — public, served to the frontend via /api/v1/config
CDP_PROJECT_ID=

# CDP Paymaster RPC URL — secret, never served to the frontend
# Contains an embedded API key. Backend proxies paymaster calls via /api/v1/paymaster
CDP_PAYMASTER_URL=

# Reserved for future E2E mock support: when set to true, a special OTP code
# ("000000") would bypass real CDP email verification and create a wallet at
# a known test address. Not implemented yet — placeholder only.
CDP_EMAIL_DEV_MODE=

# Optional
WALLETCONNECT_PROJECT_ID=
# Override generation rate limit (default: 10 in production, 1000 when MOCK_3D_GENERATION=true)
GENERATION_RATE_LIMIT_MAX=
# Override upload credential rate limit (default: 20 per 60s wallet-keyed)
UPLOAD_URL_RATE_LIMIT_MAX=
# Override unpin rate limit (default: 30 per 60s wallet-keyed)
UNPIN_RATE_LIMIT_MAX=
# Override GC rate limit (default: 10 per hour wallet-keyed)
GC_RATE_LIMIT_MAX=
# Override paymaster proxy rate limit (default: 30 per minute wallet-keyed)
PAYMASTER_RATE_LIMIT_MAX=
# Admin token required to run IPFS GC via POST /api/v1/ipfs/gc
GC_ADMIN_TOKEN=
# Kill-switch: any non-empty value drops Base Sepolia from NETWORK_CONFIGS
# so the backend/indexer stays local-only
INDEXER_DISABLE_TESTNET=
