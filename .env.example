# Smart contract addresses (sync from blockchain/.env after deploy)
CONTRACT_ADDRESS=
PAID_CONTRACT_ADDRESS=
USDC_TOKEN=
BASE_CONTRACT_ADDRESS=

# IPFS storage backend: "pinata" (dev/prod) or "kubo" (automated E2E only)
IPFS_BACKEND=kubo

# Kubo settings (used when IPFS_BACKEND=kubo)
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs/

# Pinata settings (used when IPFS_BACKEND=pinata)
# PINATA_JWT is server-only — never expose it to the browser.
PINATA_JWT=
PINATA_GATEWAY=your-gateway.mypinata.cloud
PINATA_UPLOAD_TTL=60

# Nostr relay used by the chat proxy
NOSTR_RELAY_URL=ws://127.0.0.1:7777

# Nostr service private key (32-byte hex) used by the chat proxy to sign events.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOSTR_SERVICE_PRIVATE_KEY=

# Local dev
HARDHAT_RPC_URL=http://127.0.0.1:8545
MOCK_3D_GENERATION=true

# Optional
WALLETCONNECT_PROJECT_ID=
# Override generation rate limit (default: 10 in production, 1000 when MOCK_3D_GENERATION=true)
GENERATION_RATE_LIMIT_MAX=
# Override upload credential rate limit (default: 20 per 60s wallet-keyed)
UPLOAD_URL_RATE_LIMIT_MAX=
# Override unpin rate limit (default: 30 per 60s wallet-keyed)
UNPIN_RATE_LIMIT_MAX=
# Override GC rate limit (default: 10 per hour wallet-keyed)
GC_RATE_LIMIT_MAX=
# Admin token required to run IPFS GC via POST /api/v1/ipfs/gc
GC_ADMIN_TOKEN=
