# RPC endpoints — configure for your target network
# Hardhat local (Docker container):
# API_URL=http://127.0.0.1:8545
# Optimism Sepolia testnet:
API_URL=https://sepolia.optimism.io
# Optimism mainnet:
# API_URL=https://mainnet.optimism.io

