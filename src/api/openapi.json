{
  "openapi": "3.0.3",
  "info": {
    "title": "Arbesk API",
    "description": "Cloud-Native 4D Fractal Version-Controlled 3D Asset Platform \u2014 Backend API for asset generation, session management, IPFS upload credentials, burn cleanup, and Nostr comment archival. Manifest writes, parametric editing, manifest-chain walks, and token resolution are handled client-side.",
    "version": "1.0.0",
    "contact": {
      "name": "Arbesk",
      "url": "https://github.com/ahmadsayed/arbesk"
    },
    "license": {
      "name": "ISC"
    }
  },
  "servers": [
    {
      "url": "http://localhost:9090/api/v1",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Config",
      "description": "Runtime configuration"
    },
    {
      "name": "Generations",
      "description": "3D asset generation from text prompts"
    },
    {
      "name": "Sessions",
      "description": "SIWE-based session creation and invalidation"
    },
    {
      "name": "Manifests",
      "description": "Manifest schemas for reference. Manifest writes and chain walks are client-side; no backend manifest CRUD endpoints currently exist."
    },
    {
      "name": "IPFS",
      "description": "IPFS upload credentials and unpin cleanup"
    },
    {
      "name": "Contracts",
      "description": "Smart contract ABI serving"
    },
    {
      "name": "Indexer",
      "description": "Token ownership and editor-shared token discovery"
    }
  ],
  "paths": {
    "/config": {
      "get": {
        "tags": ["Config"],
        "summary": "Get runtime configuration",
        "description": "Returns the current application configuration including the deployed contract address, IPFS gateway URL, Hardhat RPC URL, and mock generation status.",
        "operationId": "getConfig",
        "responses": {
          "200": {
            "description": "Configuration object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Config"
                }
              }
            }
          }
        }
      }
    },
    "/generations": {
      "post": {
        "tags": ["Generations"],
        "summary": "Generate a 3D asset from a text prompt",
        "description": "Authenticated endpoint that checks session auth and rate limit, calls the configured 3D generation adapter, and returns the raw asset bytes to the browser. The browser uploads the asset to IPFS, constructs the manifest, and writes the manifest to IPFS directly — no server-side IPFS writes and no on-chain transaction validation.\n\n**Rate Limit:** 10 requests per hour per wallet address in production mode, 1000 in mock mode.\n\n**On-chain validation:** The backend does not validate transaction hashes. The UI calls the free- or paid-tier contract separately before/after calling this endpoint.",
        "operationId": "generateAsset",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Asset generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "code": "MISSING_PARAMS",
                    "message": "prompt and nodeId are required"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Authorization header",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "code": "MISSING_AUTH",
                    "message": "Missing Authorization header"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid/failed transaction, wrong contract, or missing payment event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Transaction hash already consumed (replay detected)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "code": "REPLAY_DETECTED",
                    "message": "This transaction has already been consumed"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "headers": {
              "X-RateLimit-Limit": {
                "schema": {
                  "type": "integer"
                },
                "description": "Max requests per window"
              },
              "X-RateLimit-Remaining": {
                "schema": {
                  "type": "integer"
                },
                "description": "Remaining requests"
              },
              "Retry-After": {
                "schema": {
                  "type": "integer"
                },
                "description": "Seconds until reset"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Cloud adapters not implemented (only in production mode)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/sessions": {
      "post": {
        "tags": ["Sessions"],
        "summary": "Create a SIWE session",
        "description": "Verifies an EIP-4361 SIWE message and signature, then issues an opaque session token valid for 24 hours.",
        "operationId": "createSession",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "signature"],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Standard SIWE message"
                  },
                  "signature": {
                    "type": "string",
                    "description": "Wallet signature over the SIWE message"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "Opaque session token"
                    },
                    "expiresAt": {
                      "type": "integer",
                      "description": "Unix milliseconds expiration time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing message or signature",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "SIWE verification failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/sessions/{token}": {
      "delete": {
        "tags": ["Sessions"],
        "summary": "Invalidate a session",
        "description": "Deletes the session token. Called on wallet disconnect.",
        "operationId": "invalidateSession",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Session invalidated"
          }
        }
      }
    },
    "/assets/snapshot-comments": {
      "post": {
        "tags": ["Comments"],
        "summary": "Snapshot Nostr comment thread for an asset",
        "description": "Queries the private Nostr relay for all kind:1 events tagged with the asset, packages them into a deterministic JSON archive, stores it on IPFS, and returns the archive CID. Called by the browser before writing a republish manifest so the archive CID can be embedded.\n\nManifests themselves are written directly to IPFS by the browser — this endpoint only handles the server-side Nostr archive work.",
        "operationId": "snapshotCommentsArchive",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tokenId", "assetId"],
                "properties": {
                  "tokenId": {
                    "type": "string",
                    "description": "On-chain token ID for the collection"
                  },
                  "assetId": {
                    "type": "string",
                    "description": "Asset identifier inside the collection manifest"
                  },
                  "chainId": {
                    "type": "integer",
                    "description": "EVM chain ID (defaults to Hardhat local)"
                  },
                  "contractAddress": {
                    "type": "string",
                    "description": "Contract address (defaults to configured address)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comments archived successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cid": {
                      "type": "string",
                      "description": "IPFS CID of the archive JSON"
                    },
                    "eventCount": {
                      "type": "integer",
                      "description": "Number of Nostr events archived"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing tokenId or assetId",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Archive failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/ipfs/upload-url": {
      "post": {
        "tags": ["IPFS"],
        "summary": "Mint a short-lived client upload credential",
        "description": "Session-gated and rate-limited per wallet. In Pinata mode returns a presigned upload URL; in Kubo mode returns the local API URL. The master Pinata JWT never reaches the client.",
        "operationId": "mintUploadCredential",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Upload credential returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "backend": {
                      "type": "string",
                      "enum": ["kubo", "pinata"]
                    },
                    "url": {
                      "type": "string",
                      "description": "Presigned upload URL or Kubo API endpoint"
                    },
                    "expiresAt": {
                      "type": "integer",
                      "description": "Unix milliseconds expiration time (Pinata only)"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/ipfs/unpin": {
      "post": {
        "tags": ["IPFS"],
        "summary": "Unpin all IPFS CIDs owned by a manifest chain",
        "description": "Called before token burn or after asset removal from a collection (the backend verifies ownership on-chain, so the token must still be live). The session wallet must own the token or be an editor (Merkle proof), and `cid` must belong to the claimed token: accepted when it equals the tokenURI CID or appears in the `assets` map of the collection manifest at tokenURI or of up to 5 `prev_asset_manifest_cid` ancestors. A body-supplied `contractAddress` must be one of the chain's configured contracts (free or paid tier); when omitted, both are tried in order. Walks `prev_asset_manifest_cid` backward, collecting manifest CIDs, thumbnail CIDs, and comments archive CIDs, then unpins them so they become GC-eligible.",
        "operationId": "unpinManifestChain",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cid", "tokenId"],
                "properties": {
                  "cid": {
                    "type": "string",
                    "description": "Starting manifest CID (typically the latest version)"
                  },
                  "tokenId": {
                    "type": "string",
                    "pattern": "^[0-9]+$",
                    "description": "Collection token ID the CID belongs to (decimal string, uint256-safe)"
                  },
                  "chainId": {
                    "type": "integer",
                    "description": "Chain ID (defaults to the backend's configured chain)"
                  },
                  "contractAddress": {
                    "type": "string",
                    "pattern": "^0x[a-fA-F0-9]{40}$",
                    "description": "Optional contract override; must be one of the chain's configured contracts (free or paid tier)"
                  },
                  "proof": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "description": "Merkle editor proof (bytes32 hex entries); required for non-owners"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unpin completed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "unpinned": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "CIDs that were unpinned"
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Per-CID unpin errors (do not fail the whole request)"
                    },
                    "durationMs": {
                      "type": "integer",
                      "description": "Time spent walking and unpinning"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation failed (VALIDATION_ERROR), invalid or unknown token (INVALID_TOKEN), contractAddress not in the chain's configured contracts (INVALID_CONTRACT), or CID not referenced by the token (CID_NOT_IN_TOKEN)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "403": {
            "description": "Session wallet is not the token owner or an editor (FORBIDDEN)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "502": {
            "description": "Token's collection manifest could not be read (COLLECTION_UNREADABLE)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },

    "/contracts/{name}/abi": {
      "get": {
        "tags": ["Contracts"],
        "summary": "Get compiled contract ABI",
        "description": "Serves the full Hardhat artifact JSON (including `abi` and `bytecode`) for a compiled Solidity contract. Requires contracts to be compiled first via Hardhat.",
        "operationId": "getContractAbi",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "Contract name (e.g. ArbeskAsset)",
            "schema": {
              "type": "string",
              "example": "ArbeskAsset"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full Hardhat artifact JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContractArtifact"
                }
              }
            }
          },
          "404": {
            "description": "ABI not found (contracts not compiled)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": {
                    "code": "ABI_NOT_FOUND",
                    "message": "Contract ABI not found. Run compile first."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/indexer/owned": {
      "get": {
        "tags": ["Indexer"],
        "summary": "List owned tokens",
        "description": "Returns token IDs owned by the given address on the given chain.",
        "operationId": "getOwnedTokens",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" }
          },
          {
            "name": "chainId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Owned token IDs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "chainId": { "type": "integer" },
                    "address": { "type": "string" },
                    "owned": { "type": "array", "items": { "type": "string" } },
                    "lastScannedBlock": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "500": { "description": "Indexer failure" }
        }
      }
    },
    "/indexer/shared": {
      "get": {
        "tags": ["Indexer"],
        "summary": "List editor-shared tokens",
        "description": "Returns token IDs where the address has the Editor role but is not the current owner.",
        "operationId": "getSharedTokens",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" }
          },
          {
            "name": "chainId",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Shared token IDs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "chainId": { "type": "integer" },
                    "address": { "type": "string" },
                    "shared": { "type": "array", "items": { "type": "string" } },
                    "lastScannedBlock": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "500": { "description": "Indexer failure" }
        }
      }
    },
    "/paymaster": {
      "post": {
        "tags": ["Paymaster"],
        "summary": "Proxy ERC-4337 paymaster JSON-RPC calls to the CDP paymaster",
        "description": "Forwards the JSON-RPC body verbatim to the configured `CDP_PAYMASTER_URL` (the API key never reaches the browser) and returns the upstream status and body unchanged. Only standard paymaster methods (`pm_*`) are proxied. Session-authenticated and wallet-keyed rate limited (default 30 requests/minute, `PAYMASTER_RATE_LIMIT_MAX`) because every call spends the deployment's paymaster quota.",
        "operationId": "proxyPaymaster",
        "security": [{ "sessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["method"],
                "properties": {
                  "jsonrpc": { "type": "string", "example": "2.0" },
                  "id": { "type": "integer", "example": 1 },
                  "method": {
                    "type": "string",
                    "pattern": "^pm_",
                    "description": "ERC-4337 paymaster JSON-RPC method",
                    "example": "pm_sponsorUserOperation"
                  },
                  "params": { "type": "array", "items": {} }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Upstream CDP response, returned verbatim" },
          "400": { "description": "Non-paymaster method rejected (PAYMASTER_METHOD_NOT_ALLOWED)" },
          "401": { "description": "Missing or invalid session token" },
          "429": { "description": "Rate limit exceeded" },
          "502": { "description": "Upstream fetch failed (PAYMASTER_UPSTREAM_ERROR)" },
          "503": { "description": "CDP_PAYMASTER_URL not configured (PAYMASTER_NOT_CONFIGURED)" }
        }
      }
    },
    "/users/resolve-email": {
      "post": {
        "tags": ["Users"],
        "summary": "Resolve a CDP end-user email to its smart account address",
        "description": "Checks whether the given email belongs to a CDP end user of this project (exact full-email match only — no listing, partial matching, or autocomplete) and, when it does, returns the user's ERC-4337 smart account address, which is the address an owner adds to a token's Merkle editor list. The response is deliberately minimal: `{ exists: false }` for unknown emails, `{ exists: true, address }` for addable users, `{ exists: true, address: null }` for users without a smart account. Never returns the userId, EOA, or the email itself. Session-authenticated and wallet-keyed rate limited (default 10 requests/minute, `USER_RESOLVE_RATE_LIMIT_MAX`) to blunt email enumeration. Requires `CDP_API_KEY_ID` / `CDP_API_KEY_SECRET`.",
        "operationId": "resolveUserEmail",
        "security": [{ "sessionAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 254,
                    "example": "alice@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolution result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["exists"],
                  "properties": {
                    "exists": { "type": "boolean" },
                    "address": {
                      "type": ["string", "null"],
                      "description": "Smart account address — present only when the email exists",
                      "example": "0x407EDfCFd16a5623012BbB778BD47A2bf861ed40"
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid email (VALIDATION_ERROR)" },
          "401": { "description": "Missing or invalid session token" },
          "429": { "description": "Rate limit exceeded" },
          "502": { "description": "CDP API call failed (CDP_LOOKUP_FAILED)" },
          "503": { "description": "CDP server API key not configured (CDP_NOT_CONFIGURED)" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Session authentication. Format: `Session <opaque-token>`. Obtain a token by signing a SIWE (EIP-4361) message via `POST /api/v1/sessions`. Tokens expire after 24 hours."
      }
    },
    "schemas": {
      "Config": {
        "type": "object",
        "properties": {
          "contractAddress": {
            "type": "string",
            "description": "Deployed ArbeskAsset contract address",
            "example": "0x1234567890abcdef1234567890abcdef12345678"
          },
          "ipfsGatewayUrl": {
            "type": "string",
            "description": "Private IPFS gateway URL",
            "example": "http://127.0.0.1:8080/ipfs/"
          },
          "hardhatRpcUrl": {
            "type": "string",
            "description": "Hardhat local network RPC URL",
            "example": "http://127.0.0.1:8545"
          },
          "mockGeneration": {
            "type": "boolean",
            "description": "Whether mock 3D generation is enabled",
            "example": true
          }
        }
      },
      "GenerationRequest": {
        "type": "object",
        "required": ["prompt", "nodeId"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Text description of the 3D asset to generate",
            "example": "A modern minimalist workbench"
          },
          "nodeId": {
            "type": "string",
            "description": "Unique identifier for this asset node",
            "example": "node_table_001"
          },
          "provider": {
            "type": "string",
            "description": "Generation provider name. Defaults to mock.",
            "example": "meshy",
            "default": "mock"
          },
          "providerKey": {
            "type": "string",
            "description": "Bring Your Own Key: user-supplied provider API key. When present, the on-chain payment/quota gate is bypassed. Never logged or persisted server-side. Max 200 chars.",
            "maxLength": 200,
            "example": "sk-..."
          }
        }
      },
      "GenerationResponse": {
        "type": "object",
        "properties": {
          "assetData": {
            "type": "string",
            "description": "Base64-encoded generated asset bytes (GLB or glTF JSON)"
          },
          "format": {
            "type": "string",
            "description": "Asset format",
            "enum": ["glb", "gltf"]
          },
          "path": {
            "type": "string",
            "description": "Suggested source file path"
          },
          "provider": {
            "type": "string",
            "description": "Provider that produced the asset"
          }
        }
      },
      "Manifest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable asset name",
            "example": "My World"
          },
          "asset_id": {
            "type": "string",
            "description": "Unique asset identifier (auto-generated if missing)",
            "example": "asset_1700000000000"
          },
          "version": {
            "type": "integer",
            "description": "Manifest version number (auto-incremented if missing)",
            "example": 3
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Unix milliseconds timestamp"
          },
          "prev_asset_manifest_cid": {
            "type": "string",
            "description": "Previous manifest CID for version chaining",
            "nullable": true
          },
          "comments_archive_cid": {
            "type": "string",
            "description": "IPFS CID of the JSON archive of Nostr comments for this asset (set on republish)",
            "nullable": true,
            "example": "bafyCommentsArchiveCid..."
          },
          "thumbnail": {
            "$ref": "#/components/schemas/Thumbnail"
          },
          "scene": {
            "type": "object",
            "required": ["nodes"],
            "properties": {
              "nodes": {
                "type": "array",
                "description": "Array of asset nodes",
                "items": {
                  "$ref": "#/components/schemas/SceneNode"
                }
              }
            }
          },
          "type": {
            "type": "string",
            "enum": ["asset"],
            "description": "Manifest type"
          }
        }
      },
      "SceneNode": {
        "type": "object",
        "required": ["node_id"],
        "properties": {
          "node_id": {
            "type": "string",
            "description": "Unique node identifier",
            "example": "node_table_001"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          },
          "type": {
            "type": "string",
            "description": "Node type",
            "enum": ["source_asset"]
          },
          "source": {
            "type": "object",
            "description": "Source mesh reference",
            "properties": {
              "cid": {
                "type": "string",
                "description": "IPFS CID of the mesh file"
              },
              "path": {
                "type": "string",
                "description": "Filename",
                "example": "asset.glb"
              },
              "format": {
                "type": "string",
                "description": "File format",
                "example": "glb"
              },
              "bundleCid": {
                "type": "string",
                "description": "Optional organizational UnixFS directory root CID"
              }
            }
          },
          "transform_matrix": {
            "type": "array",
            "description": "4\u00d74 column-major transform matrix",
            "items": {
              "type": "number"
            },
            "minItems": 16,
            "maxItems": 16
          },
          "post_processor": {
            "type": "object",
            "description": "Runtime color/scale overlay for monolithic assets. Not baked into source mesh bytes.",
            "properties": {
              "color": {
                "type": "string",
                "description": "Hex color override",
                "nullable": true,
                "example": "#FF5733"
              },
              "scale": {
                "$ref": "#/components/schemas/Scale3D"
              }
            }
          },
          "history": {
            "type": "array",
            "description": "Optional per-node provenance log. Reserved in the schema and consumed by ledger/unpin, but current generation/save paths do not populate it.",
            "items": {
              "$ref": "#/components/schemas/HistoryEntry"
            }
          },
          "child_ref": {
            "type": "object",
            "description": "Token-based dynamic child world reference",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["token"]
              },
              "chainId": {
                "type": "integer",
                "example": 31415822
              },
              "contractAddress": {
                "type": "string"
              },
              "tokenId": {
                "type": "string"
              },
              "standard": {
                "type": "string",
                "enum": ["ERC721"]
              },
              "resolution": {
                "type": "string",
                "enum": ["latest"]
              }
            }
          }
        }
      },
      "Scale3D": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0,
            "example": 1.5
          },
          "y": {
            "type": "number",
            "minimum": 0,
            "example": 1.5
          },
          "z": {
            "type": "number",
            "minimum": 0,
            "example": 1.5
          }
        }
      },
      "HistoryEntry": {
        "type": "object",
        "properties": {
          "v": {
            "type": "integer",
            "description": "Version number"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "src": {
            "type": "object",
            "properties": {
              "cid": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "format": {
                "type": "string"
              }
            }
          },
          "prompt": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "txHash": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["generation", "parametric"]
          },
          "params": {
            "type": "object",
            "properties": {
              "scale": {
                "$ref": "#/components/schemas/Scale3D"
              },
              "color": {
                "type": "string"
              }
            }
          }
        }
      },
      "Thumbnail": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["snapshot"]
          },
          "dataUrl": {
            "type": "string",
            "description": "Base64 data URL (replaced with CID on save)",
            "example": "data:image/webp;base64,UklGRiQ..."
          },
          "cid": {
            "type": "string",
            "description": "IPFS CID of the thumbnail (set by the browser after upload)"
          },
          "path": {
            "type": "string",
            "example": "thumbnail.webp"
          },
          "format": {
            "type": "string",
            "example": "webp"
          },
          "mime": {
            "type": "string",
            "enum": ["image/webp", "image/png", "image/jpeg"]
          },
          "width": {
            "type": "integer",
            "example": 512
          },
          "height": {
            "type": "integer",
            "example": 288
          },
          "bytes": {
            "type": "integer",
            "description": "Thumbnail file size"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SaveManifestResponse": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string",
            "description": "IPFS CID of the saved manifest"
          },
          "assetId": {
            "type": "string",
            "description": "Asset identifier"
          },
          "version": {
            "type": "integer",
            "description": "Manifest version number"
          }
        }
      },
      "PublishManifestRequest": {
        "type": "object",
        "required": ["scene"],
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "prev_asset_manifest_cid": {
            "type": "string",
            "nullable": true
          },
          "thumbnail": {
            "$ref": "#/components/schemas/Thumbnail"
          },
          "scene": {
            "type": "object",
            "properties": {
              "nodes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SceneNode"
                }
              }
            }
          }
        }
      },
      "PublishManifestResponse": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string",
            "description": "IPFS CID of the published manifest"
          }
        }
      },
      "HistoryEntrySummary": {
        "type": "object",
        "properties": {
          "cid": {
            "type": "string",
            "description": "Manifest CID at this version"
          },
          "version": {
            "type": "integer",
            "description": "Version number"
          },
          "name": {
            "type": "string",
            "nullable": true,
            "description": "Asset name"
          },
          "nodeCount": {
            "type": "integer",
            "description": "Number of nodes in the scene"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "Unix milliseconds"
          }
        }
      },
      "HistoryResponse": {
        "type": "object",
        "properties": {
          "chain": {
            "type": "array",
            "description": "Version chain in chronological order (oldest first)",
            "items": {
              "$ref": "#/components/schemas/HistoryEntrySummary"
            }
          }
        }
      },
      "TokenManifestResponse": {
        "type": "object",
        "properties": {
          "tokenId": {
            "type": "string",
            "description": "The on-chain token ID"
          },
          "manifestCid": {
            "type": "string",
            "description": "IPFS CID of the manifest"
          },
          "manifest": {
            "$ref": "#/components/schemas/Manifest"
          }
        }
      },
      "ContractArtifact": {
        "type": "object",
        "properties": {
          "abi": {
            "type": "array",
            "description": "Contract ABI",
            "items": {
              "type": "object"
            }
          },
          "bytecode": {
            "type": "string",
            "description": "Deployed bytecode"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code",
                "example": "REPLAY_DETECTED"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message",
                "example": "This transaction has already been consumed"
              },
              "details": {
                "description": "Optional additional error context",
                "oneOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}
