{
  "name": "arbesk",
  "type": "module",
  "version": "0.1.0",
  "description": "Arbesk — 4D Fractal Version-Controlled 3D Asset Platform. Cloud-native 3D generation meets decentralized scene graphs.",
  "main": "src/index.js",
  "scripts": {
    "test": "IPFS_BACKEND=kubo NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "test:contracts": "docker compose -p ${COMPOSE_PROJECT_NAME:-arbesk} run --rm hardhat npx hardhat test",
    "build:frontend": "cd frontend && npm run build",
    "start": "node src/index.js",
    "nodemon": "npm run build:frontend && nodemon src/index.js",
    "dev": "./scripts/start-dev.sh",
    "dev:testnet": "./scripts/start-dev.sh --testnet",
    "test:api": "IPFS_BACKEND=kubo NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest test/api.test.js --runInBand --silent",
    "test:frontend": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest test/frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:all": "npm run lint && npm run typecheck && npm run typecheck:frontend && npm run test:frontend && npm run test:api && npm run test:contracts",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "tsc --noEmit -p frontend/tsconfig.json",
    "test:e2e": "NODE_OPTIONS='' playwright test --config=e2e/playwright.config.js",
    "test:e2e:ui": "NODE_OPTIONS='' playwright test --config=e2e/playwright.config.js --ui",
    "test:e2e:coverage": "node scripts/run-e2e-coverage.mjs",
    "test:coverage": "npm run test:coverage:js && npm run test:coverage:contracts",
    "test:coverage:js": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --coverage --coverageDirectory=coverage/js",
    "test:coverage:all": "npm run test:coverage:js && npm run test:e2e:coverage && node scripts/merge-all-coverage.mjs",
    "test:coverage:contracts": "docker compose -p ${COMPOSE_PROJECT_NAME:-arbesk} run --rm hardhat npx hardhat coverage && docker run --rm -v $(pwd)/blockchain/coverage:/cov alpine sh -c 'chown -R $(stat -c \"%u:%g\" /cov) /cov'",
    "worktree:create": "./scripts/create-worktree.sh",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmadsayed/arbesk.git"
  },
  "license": "ISC",
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.53.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "commander": "^15.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ipfs-http-client": "^60.0.0",
    "morgan": "^1.11.0",
    "nostr-tools": "^2.23.5",
    "pinata": "^2.5.6",
    "siwe": "^3.0.0",
    "viem": "^2.52.2",
    "web3": "^4.15.0",
    "web3-utils": "^4.3.3",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.6.0",
    "fflate": "^0.8.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.0.0",
    "playwright": "^1.60.0",
    "supertest": "^6.3.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "eslint"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
